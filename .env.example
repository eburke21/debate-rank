# DebateRank Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ─── Required ───────────────────────────────────────────────────

# Anthropic API key for Claude judge evaluations
# Get one at: https://console.anthropic.com/
# Cost: ~$0.10-0.30 to evaluate 12 seed arguments
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional (defaults are set for Docker Compose local dev) ──

# Database connection string
# Default: postgresql+asyncpg://debaterank:localdev@db:5432/debaterank
# For local development without Docker, use:
#   postgresql+asyncpg://debaterank:localdev@localhost:5432/debaterank
# DATABASE_URL=postgresql+asyncpg://debaterank:localdev@db:5432/debaterank

# CORS allowed origins (comma-separated)
# Default: http://localhost:5173
# CORS_ORIGINS=http://localhost:5173

# Rate limit for argument submissions (per minute per IP)
# Default: 10
# RATE_LIMIT_PER_MINUTE=10

# Host port for the Docker Compose Postgres container
# Default: 5432. Set this if another local Postgres already binds 5432
# (Docker Compose reads it automatically from .env). The container always
# listens on 5432 internally, so this only changes the *host* port. If you
# override it, host-run commands (alembic/seed/psql) must target the new port,
# e.g. postgresql+asyncpg://debaterank:localdev@localhost:5433/debaterank
# DB_PORT=5433
