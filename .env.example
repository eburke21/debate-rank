# DebateRank Environment Variables
# Copy this file to .env and fill in the values

# Required: Anthropic API key for Claude judge evaluations
ANTHROPIC_API_KEY=sk-ant-...

# Database connection (defaults are set for Docker Compose local dev)
# DATABASE_URL=postgresql+asyncpg://debaterank:localdev@db:5432/debaterank

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173

# Rate limit for argument submissions (per minute per IP)
# RATE_LIMIT_PER_MINUTE=10

# Logging level
# LOG_LEVEL=INFO
